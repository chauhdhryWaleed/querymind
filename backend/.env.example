# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=openparley

# CORS: comma-separated origins. "*" is ignored for credentialed (cookie) requests
# and falls back to the dev frontend origins; set explicit origins in production.
CORS_ORIGINS=*

# Optional gateway key. Empty disables the X-API-Key check on all routes but /health.
API_KEY=

# Database (read-write; used by Alembic and query-history writes).
DATABASE_URL=postgresql+asyncpg://openparley:openparley@localhost:5433/openparley
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Demo database: one-click sample connection seeded on the same Postgres server.
# Host and port are derived from DATABASE_URL.
DEMO_DB_ENABLED=true
DEMO_DB_NAME=demo
DEMO_DB_USER=openparley_reader
DEMO_DB_PASSWORD=openparley_reader

# Redis (sessions, rate limiting).
REDIS_URL=redis://localhost:6380/0
SESSION_TTL=86400
REFRESH_TTL=2592000

# Auth: failed-attempt rate limit (slowapi syntax).
AUTH_RATE_LIMIT=5/15minutes

# Email (Resend) and links embedded in transactional emails.
RESEND_API_KEY=
EMAIL_FROM=Open Parley <onboarding@resend.dev>
FRONTEND_URL=http://localhost:3000

# LLM model defaults (per-request keys are BYOK, entered in the app).
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2048

# Execution limits.
MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30.0
MAX_RETRIES=3

# Result UX
MAX_VISUALIZABLE_ROWS=200

# Observability: leave OTEL_ENDPOINT empty to disable OTLP export.
OTEL_ENDPOINT=
OTEL_ENABLE_INSTRUMENTATION=true
